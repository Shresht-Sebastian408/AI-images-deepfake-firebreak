{
  "manifest_version": 3,
  "name": "AI Media Detector",
  "version": "1.0",
  "description": "Detects AI-generated images and videos and alerts the user.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
